{
	"name": "mobileapp",
	"version": "1.0.0",
	"scripts": {
		"dev": "vite dev",
		"build": "npm run indexing && npm run sync-ionic-types && npm run validate && vite build --mode production",
		"preview": "vite preview --mode production",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write . && eslint . --fix",
		"lint": "prettier --check . && eslint .",
		"validate": "npm run check && npm run lint && npm run i18n",
		"test:ui": "vitest --ui",
		"test": "vitest -- --run",
		"doc": "typedoc & live-server ./docs --watch --silent --no-browser --port=1234 & chokidar 'src/lib' -c 'typedoc' --silent",
		"build-android": "cross-env ADAPTER=static npm run build && dotenv cross-env-shell 'cap sync && ./android/gradlew -p android assembleDebug'",
		"build-web": "cross-env ADAPTER=node npm run build",
		"visualize": "mkdir -p visualize && madge --extensions ts,svelte --image visualize/dependency-graph.png src",
		"indexing": "tsx ./src/lib/utility/indexing.utility.ts",
		"sync-ionic-types": "tsx ./src/lib/utility/sync-ionic-types.ts && prettier --write ./src/app.d.ts && eslint ./src/app.d.ts --fix",
		"i18n": "i18n-unused display-unused && i18n-unused display-missed"
	},
	"type": "module",
	"devDependencies": {
		"@capacitor/android": "^7.4.4",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^7.4.4",
		"@capacitor/core": "^7.4.4",
		"@eslint/js": "^9.39.1",
		"@kollapp/api-types": "^0.9.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/package": "^2.5.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@testing-library/svelte": "^5.2.9",
		"@types/d3": "^7.4.3",
		"@types/eslint-plugin-security": "^3.0.0",
		"@types/eslint-plugin-tailwindcss": "^3.17.0",
		"@types/estree": "^1.0.8",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^24.10.1",
		"@vitest/coverage-v8": "^4.0.9",
		"@vitest/ui": "^4.0.9",
		"chokidar-cli": "^3.0.0",
		"cross-env": "^10.1.0",
		"dotenv-cli": "^11.0.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-perfectionist": "^4.15.1",
		"eslint-plugin-security": "^3.0.1",
		"eslint-plugin-sonarjs": "^3.0.5",
		"eslint-plugin-svelte": "^3.13.0",
		"eslint-plugin-tailwindcss": "^3.18.2",
		"eslint-plugin-unicorn": "^62.0.0",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"i18n-unused": "^0.19.0",
		"jsdom": "^27.2.0",
		"live-server": "^1.2.2",
		"madge": "^8.0.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.43.6",
		"svelte-check": "^4.3.4",
		"tsx": "^4.20.6",
		"typedoc": "^0.28.14",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.4",
		"uuid": "^13.0.0",
		"vite": "^7.2.2",
		"vitest": "^4.0.9"
	},
	"dependencies": {
		"@capacitor/app": "^7.1.0",
		"@capacitor/app-launcher": "^7.0.2",
		"@capacitor/barcode-scanner": "^2.2.0",
		"@capacitor/browser": "^7.0.2",
		"@capacitor/clipboard": "^7.0.2",
		"@capacitor/device": "^7.0.2",
		"@capacitor/haptics": "^7.0.2",
		"@capacitor/network": "^7.0.2",
		"@capacitor/preferences": "^7.0.2",
		"@capacitor/push-notifications": "^7.0.3",
		"@capacitor/share": "^7.0.2",
		"@capacitor/splash-screen": "^7.0.3",
		"@capgo/capacitor-native-biometric": "^7.5.1",
		"@date-fns/tz": "^1.4.1",
		"@ebarooni/capacitor-calendar": "^7.2.0",
		"@edde746/svelte-apexcharts": "^2.1.0",
		"@ionic/core": "^8.7.9",
		"@ionic/pwa-elements": "^3.3.0",
		"@svelte-put/qr": "^2.1.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"apexcharts": "^5.3.6",
		"capacitor-email-composer": "^7.0.2",
		"capacitor-secure-storage-plugin": "^0.12.0",
		"d3": "^7.9.0",
		"date-fns": "^4.1.0",
		"ionicons": "^8.0.13",
		"leaflet": "2.0.0-alpha.1",
		"sveltekit-i18n": "^2.4.2",
		"tailwind-scrollbar-hide": "^4.0.0",
		"tailwindcss": "^4.1.17",
		"yup": "^1.7.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@sveltejs/kit",
			"@tailwindcss/oxide",
			"esbuild",
			"sharp"
		]
	}
}
