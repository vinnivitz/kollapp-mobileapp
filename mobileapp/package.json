{
	"name": "mobileapp",
	"version": "1.0.0",
	"scripts": {
		"dev": "cross-env NODE_ENV=development vite dev",
		"build": "cross-env NODE_ENV=production && npm run index-searchables && vite build",
		"preview": "cross-env NODE_ENV=production vite preview",
		"check": "cross-env NODE_ENV=development svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write . && eslint . --fix",
		"lint": "prettier --check . && eslint .",
		"validate": "npm run check && npm run lint",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"typedoc": "typedoc & live-server ./docs --watch --silent --no-browser --port=1234 & chokidar 'src/lib' -c 'typedoc' --silent",
		"build-android": "npm run build && dotenv cross-env-shell 'cap sync && cap open android'",
		"visualize": "mkdir -p visualize && madge --extensions ts,svelte --image visualize/dependency-graph.png src",
		"index-searchables": "tsx ./src/index-searchables.ts"
	},
	"type": "module",
	"devDependencies": {
		"@capacitor/android": "^6.2.0",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^6.2.0",
		"@capacitor/core": "^6.2.0",
		"@eslint/js": "^9.22.0",
		"@playwright/test": "^1.51.0",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.19.0",
		"@sveltejs/package": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^4.0.4",
		"@testing-library/svelte": "^5.2.7",
		"@types/estree": "^1.0.6",
		"@types/node": "^22.13.10",
		"@types/uuid": "^10.0.0",
		"autoprefixer": "^10.4.21",
		"chokidar-cli": "^3.0.0",
		"cross-env": "^7.0.3",
		"dotenv-cli": "^8.0.0",
		"eslint": "^9.22.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-security": "^3.0.1",
		"eslint-plugin-sonarjs": "^3.0.2",
		"eslint-plugin-sort": "^4.0.0",
		"eslint-plugin-svelte": "^2.46.1",
		"eslint-plugin-tailwindcss": "^3.18.0",
		"eslint-plugin-unicorn": "^56.0.1",
		"globals": "^15.15.0",
		"husky": "^9.1.7",
		"jsdom": "^25.0.1",
		"live-server": "^1.2.2",
		"madge": "^8.0.0",
		"playwright": "^1.51.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.22.6",
		"svelte-check": "^4.1.5",
		"tsx": "^4.19.3",
		"typedoc": "^0.27.9",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.26.0",
		"uuid": "^11.1.0",
		"vite": "^5.4.14",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@capacitor/app": "^6.0.2",
		"@capacitor/device": "^6.0.2",
		"@capacitor/network": "^6.0.3",
		"@capacitor/preferences": "^6.0.3",
		"@ionic/core": "^8.4.3",
		"@ionic/pwa-elements": "^3.3.0",
		"@tailwindcss/typography": "^0.5.16",
		"ionic-svelte": "^0.5.85",
		"ionicons": "^7.4.0",
		"loader": "link:@ionic/pwa-elements/loader",
		"moment": "^2.30.1",
		"sveltekit-i18n": "^2.4.2",
		"tailwind-scrollbar-hide": "^1.3.1",
		"tailwindcss": "^3.4.17",
		"yup": "^1.6.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@sveltejs/kit",
			"esbuild",
			"sharp"
		]
	}
}
