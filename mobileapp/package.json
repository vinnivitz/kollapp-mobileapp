{
	"name": "mobileapp",
	"version": "0.1.0",
	"scripts": {
		"dev": "vite dev",
		"build": "npm run indexing && npm run sync-ionic-types && npm run validate && vite build --mode production",
		"preview": "vite preview --mode production",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write . && eslint . --fix",
		"lint": "prettier --check . && eslint .",
		"validate": "npm run check && npm run lint && npm run i18n",
		"test:ui": "vitest --ui",
		"test": "vitest -- --run",
		"doc": "typedoc & live-server ./docs --watch --silent --no-browser --port=1234 & chokidar 'src/lib' -c 'typedoc' --silent",
		"build-android": "cross-env ADAPTER=static npm run build && dotenv cross-env-shell 'cap sync && ./android/gradlew -p android assembleDebug'",
		"run-android": "cross-env ADAPTER=static npm run build && cross-env-shell 'cap run android'",
		"build-web": "cross-env ADAPTER=node npm run build",
		"visualize": "mkdir -p visualize && madge --extensions ts,svelte --image visualize/dependency-graph.png src",
		"indexing": "tsx ./src/lib/utility/indexing.utility.ts",
		"sync-ionic-types": "tsx ./src/lib/utility/sync-ionic-types.ts && prettier --write ./src/app.d.ts && eslint ./src/app.d.ts --fix",
		"i18n": "OUTPUT=$(i18n-unused display-unused && i18n-unused display-missed) && echo \"$OUTPUT\" && echo \"$OUTPUT\" | grep -qE 'Total unused translations count: 0' && echo \"$OUTPUT\" | grep -qE 'Total missed.*count: 0'"
	},
	"type": "module",
	"devDependencies": {
		"@capacitor/android": "^8.0.2",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^8.0.2",
		"@capacitor/core": "^8.0.2",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@kollapp/api-types": "^0.9.0",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^5.3.1",
		"@types/d3": "^7.4.3",
		"@types/eslint-plugin-tailwindcss": "^3.17.0",
		"@types/estree": "^1.0.8",
		"@types/file-saver": "^2.0.7",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.2.2",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"baseline-browser-mapping": "^2.9.19",
		"chokidar-cli": "^3.0.0",
		"cross-env": "^10.1.0",
		"dotenv-cli": "^11.0.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-perfectionist": "^5.5.0",
		"eslint-plugin-sonarjs": "^3.0.6",
		"eslint-plugin-svelte": "^3.14.0",
		"eslint-plugin-tailwindcss": "^3.18.2",
		"eslint-plugin-unicorn": "^62.0.0",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"i18n-unused": "^0.19.0",
		"jsdom": "^28.0.0",
		"live-server": "^1.2.2",
		"madge": "^8.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.50.0",
		"svelte-check": "^4.3.6",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.16",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"uuid": "^13.0.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@capacitor/app": "^8.0.0",
		"@capacitor/app-launcher": "^8.0.0",
		"@capacitor/barcode-scanner": "^3.0.1",
		"@capacitor/browser": "^8.0.0",
		"@capacitor/clipboard": "^8.0.0",
		"@capacitor/device": "^8.0.0",
		"@capacitor/file-viewer": "^2.0.0",
		"@capacitor/filesystem": "^8.1.0",
		"@capacitor/haptics": "^8.0.0",
		"@capacitor/network": "^8.0.0",
		"@capacitor/preferences": "^8.0.0",
		"@capacitor/push-notifications": "^8.0.0",
		"@capacitor/share": "^8.0.0",
		"@capacitor/splash-screen": "^8.0.0",
		"@capawesome/capacitor-app-shortcuts": "^8.0.0",
		"@capgo/capacitor-native-biometric": "^8.3.7",
		"@date-fns/tz": "^1.4.1",
		"@dnd-kit-svelte/svelte": "^0.1.6",
		"@dnd-kit/helpers": "^0.2.4",
		"@ebarooni/capacitor-calendar": "^8.0.0",
		"@edde746/svelte-apexcharts": "^2.1.0",
		"@ionic/core": "^8.7.11",
		"@ionic/pwa-elements": "^3.3.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@trasherdk/svelte-qrcode": "^0.2.4",
		"apexcharts": "^5.3.6",
		"capacitor-email-composer": "^8.0.0",
		"capacitor-secure-storage-plugin": "^0.13.0",
		"d3": "^7.9.0",
		"date-fns": "^4.1.0",
		"driver.js": "^1.4.0",
		"file-saver": "^2.0.5",
		"html-to-image": "^1.11.13",
		"ionicons": "^8.0.13",
		"jspdf": "^4.1.0",
		"leaflet": "2.0.0-alpha.1",
		"sveltekit-i18n": "^2.4.2",
		"tailwind-scrollbar-hide": "^4.0.0",
		"tailwindcss": "^4.1.18",
		"yup": "^1.7.1"
	},
	"pnpm": {
		"overrides": {
			"@types/node": "^24.10.12"
		}
	}
}
