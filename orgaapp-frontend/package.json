{
	"name": "orgaapp-frontend",
	"version": "0.0.1",
	"scripts": {
		"dev": "NODE_ENV=development vite dev",
		"build": "NODE_ENV=production vite build",
		"preview": "NODE_ENV=production vite preview",
		"check": "NODE_ENV=development svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write . && eslint . --fix",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"typedoc": "typedoc & live-server ./docs --watch --silent --no-browser --port=1234 & chokidar 'src/lib/utils' -c 'typedoc && touch ./docs/.reload' --silent"
	},
	"type": "module",
	"devDependencies": {
		"@playwright/test": "^1.45.3",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"autoprefixer": "^10.4.20",
		"chokidar-cli": "^3.0.0",
		"eslint": "^9.14.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-security": "^3.0.1",
		"eslint-plugin-svelte": "^2.36.0",
		"eslint-plugin-tailwindcss": "^3.17.5",
		"eslint-plugin-unicorn": "^56.0.1",
		"globals": "^15.0.0",
		"husky": "^9.1.7",
		"live-server": "^1.2.2",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.9",
		"typedoc": "^0.27.2",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.0.11",
		"vitest": "^2.0.4"
	},
	"dependencies": {
		"@capacitor/app": "^6.0.2",
		"@capacitor/device": "^6.0.2",
		"@capacitor/network": "^6.0.3",
		"@capacitor/preferences": "^6.0.3",
		"@ionic/core": "^8.4.1",
		"@ionic/pwa-elements": "^3.3.0",
		"@tailwindcss/typography": "^0.5.15",
		"@types/node": "^22.10.1",
		"ionic-svelte": "^0.5.85",
		"ionicons": "^7.4.0",
		"sveltekit-i18n": "^2.4.2",
		"tailwind-scrollbar-hide": "^1.1.7",
		"yup": "^1.4.0"
	}
}
