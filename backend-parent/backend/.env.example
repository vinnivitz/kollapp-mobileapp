# Database Configuration
MYSQL_DATABASE=kollapp
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=admin
MYSQL_PASSWORD=pass

# Backend Application
BACKEND_APPLICATION_NAME=kollapp-backend
BACKEND_DB_HOST=localhost
BACKEND_DB_PORT=3306
BACKEND_DB_USER=admin
BACKEND_DB_PASSWORD=pass

# Mail Configuration
BACKEND_MAIL_HOST=localhost
BACKEND_MAIL_PORT=1025
BACKEND_MAIL_USER=
BACKEND_MAIL_PASSWORD=
BACKEND_MAIL_AUTH=false
BACKEND_MAIL_STARTTLS=false

# Application Settings
BACKEND_PORT=8080
BACKEND_DOMAIN=localhost
BACKEND_HOST=localhost
BACKEND_PRODUCTION=false
BACKEND_STATIC_CACHE_DAYS=365
BACKEND_ORGANIZATION_INVITATION_VALIDITY_DAYS=3

# Client URLs
BACKEND_CLIENT_WEB_URL=http://localhost:5173
BACKEND_CLIENT_ANDROID_URL=kollapp:/

# CORS Configuration
BACKEND_CORS_URL=http://localhost:*
BACKEND_CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
BACKEND_CORS_HEADERS=Content-Type,Authorization,Accept,X-Requested-With
BACKEND_CORS_EXPOSED_HEADERS=Authorization,Content-Disposition
BACKEND_CORS_CREDENTIALS=true

# Rate Limiting
BACKEND_RATE_LIMIT=10
BACKEND_RATE_LIMIT_TIME=60

# JWT Secrets
BACKEND_JWT_AUTH_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
BACKEND_JWT_AUTH_EXPIRATION_IN_SECONDS=86400
BACKEND_JWT_REFRESH_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
BACKEND_JWT_REFRESH_EXPIRATION_IN_SECONDS=2592000
BACKEND_JWT_CONFIRMATION_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
BACKEND_JWT_CONFIRMATION_EXPIRATION_IN_SECONDS=3600
BACKEND_JWT_RESET_PASSWORD_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
BACKEND_JWT_RESET_PASSWORD_EXPIRATION_IN_SECONDS=3600
